{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    ":enableVulnerabilityAlerts"
  ],
  "minimumReleaseAge": "4 days",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true
    },
    {
      "automerge": true,
      "extends": ["packages:linters", "packages:test"]
    },
    {
      "matchPackageNames": [
        "coverlet.collector"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "matchPackageNames": [
        "@types{/,}**"
      ]
    }
  ]
}
